<?xml version="1.0" encoding="utf-8"?>

<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- CONTENIDO PRINCIPAL-->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="0dp"
            android:background="#E8F5E9">

            <!-- HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/fondo2"
                android:padding="0dp">

                <ImageView
                    android:id="@+id/imgPerfil"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:layout_gravity="bottom|start"
                    android:layout_marginStart="1dp"
                    android:layout_marginBottom="10dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/logoagro" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/ubic"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/btnMenu"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:src="@android:drawable/ic_menu_sort_by_size" />

            </LinearLayout>

            <!-- MAPA -->
            <ImageView
                android:id="@+id/imgMapa"
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:layout_marginTop="15dp"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:scaleType="centerCrop"
                android:src="@drawable/mapaagroo1" />

            <!-- HORARIO -->
            <TextView
                android:id="@+id/txtHorario"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Horario:"
                android:textStyle="bold"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:textSize="20sp"
                android:layout_marginTop="16dp"
                android:gravity="center"/>

            <TextView
                android:id="@+id/txtHorario1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sábados y domingos de 9:00 am a 18:00pm hrs."
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:textSize="16sp"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:textStyle="normal"
                android:layout_marginBottom="20dp"/>

            <!-- INDICACIONES -->
            <TextView
                android:id="@+id/txtIndicaciones"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Indicaciones para llegar:"
                android:layout_marginTop="10dp"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:textSize="20sp"
                android:gravity="center"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/textIndicacines1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="El Mercado Agromexiquense está en el Andador Miguel Enríquez, en el centro de Villa del Carbón. Para ubicarte ve al Parque Principal con su kiosco de cantera rosa. Enfrente está la Parroquia de la Virgen de la Peña de Francia. El andador es la calle peatonal entre la iglesia y el parque. Ahí encuentras los puestos con quesos, miel, trucha y artesanías."
                android:layout_marginStart="14dp"
                android:layout_marginRight="14dp"
                android:layout_marginEnd="14dp"
                android:textSize="16sp"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:textStyle="normal"/>

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="14dp"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"
                android:scaleType="centerCrop"
                android:src="@drawable/im"/>

        </LinearLayout>

    </ScrollView>

    <!-- MENÚ LATERAL-->
    <LinearLayout
        android:id="@+id/menuLateral"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start">

        <include layout="@layout/menu_lateral" />

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>